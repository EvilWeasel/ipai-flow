# OpenAI-compatible endpoint (optional). Leave OPENAI_API_KEY empty to run
# fully offline — the app falls back to a simple extractive summariser
# and a heuristic moderator.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# SQLite database location (defaults to data/ipai-flow.db)
DATABASE_FILE=data/ipai-flow.db
