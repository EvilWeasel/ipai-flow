# PGX OpenAI-compatible endpoint (optional). Leave PGX_API_KEY empty to run
# fully offline — the app falls back to a simple extractive summariser
# and a heuristic moderator.
PGX_API_KEY=
PGX_MODEL=gemma-4-26b
PGX_URL_BASE=https://pgxapi.siller.io/v1/chat/completions

# Supabase credentials. Put real values in .env.local, not here.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Optional but preferred for this server-only data layer.
SUPABASE_SERVICE_ROLE_KEY=
